<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="64dp" android:padding="16dp">

    <TextView android:id="@+id/notification_title" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_alignParentStart="true"
        android:layout_centerVertical="true" android:text="Task in progress"
        android:textColor="@android:color/black" android:textSize="16sp" android:textStyle="bold" />

    <TextView android:id="@+id/notification_timer" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_alignParentEnd="true"
        android:layout_centerVertical="true" android:text="00:10"
        android:textColor="@android:color/holo_blue_dark" android:textSize="24sp"
        android:textStyle="bold" />

</RelativeLayout>